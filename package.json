{
  "name": "markdown-viewer-mac",
  "version": "0.1.0",
  "description": "A native macOS Markdown viewer and editor with secure live preview, direct file opening, and local exports.",
  "author": "Shibanshu Jha",
  "main": "electron/main.cjs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "start": "electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder --mac dir",
    "dist": "npm run build:renderer && electron-builder --mac dmg",
    "check": "npm run build:renderer && node scripts/smoke-check.mjs"
  },
  "build": {
    "appId": "com.shibanshujha.markdownviewermac",
    "productName": "Markdown Viewer Mac",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "identity": null,
      "target": [
        "dir",
        "dmg"
      ]
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor",
        "rank": "Owner"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor",
        "rank": "Owner"
      },
      {
        "ext": "mdown",
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor",
        "rank": "Alternate"
      }
    ]
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "github-markdown-css": "^5.9.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "lucide": "^1.23.0",
    "marked": "^18.0.5",
    "mermaid": "^11.16.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "vite": "^8.1.3",
    "wait-on": "^9.0.10"
  }
}
